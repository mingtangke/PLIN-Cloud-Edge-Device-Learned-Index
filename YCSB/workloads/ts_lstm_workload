# 基础配置
workload=site.ycsb.workloads.TimeSeriesWorkload
recordcount=10000000  # 与C++代码中的total_keys一致
operationcount=40000000  # 10设备 × 4周期 × 1000000请求/设备

# 时间序列配置
timestampunits=SECONDS
timestampinterval=1  # 每秒一个数据点
fieldcount=10  # 与num_devices一致
fieldlength=8

# 标签配置(模拟设备ID)
tagcount=1
tagcardinality=10  # 与num_devices一致
tagkeylength=8
tagvaluelength=8

# 操作比例
readproportion=1.0  # 所有操作都是查找
insertproportion=0.0
updateproportion=0.0

# 请求分布
requestdistribution=zipfian
zipfianconstant=1.2  # 与C++代码中的zipf_param一致

# 查询配置
querytimespan=0  # 点查询